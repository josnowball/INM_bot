{
  "manifest_version": 3,
  "name": "CitaFacil — INM & SRE Auto-Fill",
  "version": "1.0.0",
  "description": "One-click form filling for Mexican government appointment sites (INM & SRE). Free forever.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://citas.sre.gob.mx/*",
    "https://citas.inm.gob.mx/*",
    "https://miconsulado.sre.gob.mx/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://citas.sre.gob.mx/*", "https://miconsulado.sre.gob.mx/*"],
      "js": ["content_sre.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://citas.inm.gob.mx/*"],
      "js": ["content_inm.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "CitaFacil"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
